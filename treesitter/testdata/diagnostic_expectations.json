{
  "scenarios": [
    {
      "name": "single_error_unquoted_value",
      "description": "Unquoted value produces a single deduplicated ERROR at the tightest range",
      "source": "{\"broken\": bad}",
      "language": ".json",
      "checks": [
        {
          "name": "syntax-errors",
          "pattern": "(ERROR) @error",
          "severity": 1,
          "message": "syntax error",
          "deduplicate_nested": true
        }
      ],
      "expected": [
        {
          "message": "syntax error",
          "severity": 1,
          "source": "syntax-errors",
          "range": {
            "start": {
              "line": 0,
              "character": 11
            },
            "end": {
              "line": 0,
              "character": 14
            }
          }
        }
      ]
    },
    {
      "name": "multiline_error_on_line2",
      "description": "Error on a specific line in multi-line JSON, deduplicated to tightest range",
      "source": "{\n  \"a\": 1,\n  \"b\": bad,\n  \"c\": 3\n}",
      "language": ".json",
      "checks": [
        {
          "name": "syntax-errors",
          "pattern": "(ERROR) @error",
          "severity": 1,
          "message": "syntax error",
          "deduplicate_nested": true
        }
      ],
      "expected": [
        {
          "message": "syntax error",
          "severity": 1,
          "source": "syntax-errors",
          "range": {
            "start": {
              "line": 2,
              "character": 7
            },
            "end": {
              "line": 2,
              "character": 10
            }
          }
        }
      ]
    },
    {
      "name": "multiple_errors_different_lines",
      "description": "Two unquoted values on separate lines produce two distinct deduplicated ERROR ranges",
      "source": "{\n  \"a\": bad1,\n  \"b\": bad2\n}",
      "language": ".json",
      "checks": [
        {
          "name": "syntax-errors",
          "pattern": "(ERROR) @error",
          "severity": 1,
