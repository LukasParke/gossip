      "expected": [
        {
          "message": "syntax error",
          "severity": 1,
          "source": "syntax-errors",
          "range": {
            "start": {
              "line": 1,
              "character": 7
            },
            "end": {
              "line": 1,
              "character": 10
            }
          }
        },
        {
          "message": "syntax error",
          "severity": 1,
          "source": "syntax-errors",
          "range": {
            "start": {
              "line": 2,
              "character": 7
            },
            "end": {
              "line": 2,
              "character": 10
            }
          }
        }
      ]
    },
